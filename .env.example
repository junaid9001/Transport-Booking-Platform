# Root-level variables used by docker-compose.yml
# Use host.docker.internal so containers can reach your host Postgres.
AUTH_DB=postgres://postgres:password@host.docker.internal:5432/tripneo_auth?sslmode=disable
FLIGHT_DB=postgres://postgres:password@host.docker.internal:5432/tripneo_flight?sslmode=disable
TRAIN_DB=postgres://postgres:password@host.docker.internal:5432/tripneo_train?sslmode=disable
BUS_DB=postgres://postgres:password@host.docker.internal:5432/tripneo_bus?sslmode=disable

# Frontend origin for CORS/proxy behavior
FRONTEND_URL=http://localhost:3000
